# MongoDB (required for this app’s better-auth adapter)
MONGODB_URI=

# Public URL of this app — must match Google OAuth “Authorized redirect URIs” host
# Redirect path is always: {baseURL}/api/auth/callback/google
# Example local: http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (Credentials → OAuth 2.0 Client IDs)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Destinations REST API (JSON). If wrong or down, pages show empty / 404 instead of crashing.
# Example: http://localhost:8000
NEXT_PUBLIC_WANDERLUST_API_URL=http://localhost:8000
